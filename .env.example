# Copy to `.env` and edit. `.env` is gitignored.
# All values are optional when using `just backend` (dev defaults apply); set
# them here to override. Variables already exported in your shell win.

# Bearer token every non-/health API route requires.
DEARBORN_TOKEN=dev-token

# AES-256-GCM key material used to encrypt PATs at rest.
DEARBORN_MASTER_KEY=dev-master-key

# Bind address for the HTTP server.
DEARBORN_BIND=127.0.0.1:8787

# Local libSQL/SQLite database file.
# DEARBORN_DB=./dearborn.db

# Per-project clone root.
# DEARBORN_CLONE_ROOT=./clones

# Built SPA assets served at / (absent => API only).
# DEARBORN_STATIC_DIR=./client/dist
